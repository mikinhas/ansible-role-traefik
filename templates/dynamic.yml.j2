http:
{% if traefik_http_routers %}
  routers:
{% for router in traefik_http_routers %}
{% if router.tls | default(false) %}
    {{ router.name }}-http:
      rule: "{{ router.rule }}"
      service: {{ router.service }}
      entryPoints:
        - web
      middlewares:
        - https-redirect
    {{ router.name }}:
      rule: "{{ router.rule }}"
      service: {{ router.service }}
      entryPoints:
        - websecure
      middlewares:
        - security-headers
{% if traefik_acme_email %}
      tls:
        certResolver: letsencrypt
{% endif %}
{% else %}
    {{ router.name }}:
      rule: "{{ router.rule }}"
      service: {{ router.service }}
      entryPoints:
        - web
{% endif %}
{% endfor %}
{% endif %}

{% if traefik_services %}
  services:
{% for service in traefik_services %}
    {{ service.name }}:
      loadBalancer:
        servers:
{% for url in service.urls %}
          - url: "{{ url }}"
{% endfor %}
{% endfor %}
{% endif %}

  middlewares:
    https-redirect:
      redirectScheme:
        scheme: https
        permanent: true
    security-headers:
      headers:
        stsSeconds: 31536000
        stsIncludeSubdomains: true
        stsPreload: true
        forceSTSHeader: true
        contentTypeNosniff: true
        browserXssFilter: true
        frameDeny: true
        referrerPolicy: "strict-origin-when-cross-origin"

{% if traefik_tcp_routers or traefik_tcp_services %}
tcp:
{% if traefik_tcp_routers %}
  routers:
{% for router in traefik_tcp_routers %}
    {{ router.name }}:
      entryPoints:
        - {{ router.entrypoint }}
      rule: "{{ router.rule }}"
      service: {{ router.service }}
{% endfor %}
{% endif %}
{% if traefik_tcp_services %}
  services:
{% for service in traefik_tcp_services %}
    {{ service.name }}:
      loadBalancer:
        servers:
{% for url in service.urls %}
          - address: "{{ url }}"
{% endfor %}
{% endfor %}
{% endif %}
{% endif %}

tls:
  options:
    default:
      minVersion: VersionTLS12
      cipherSuites:
        - TLS_ECDHE_RSA_WITH_AES_256_GCM_SHA384
        - TLS_ECDHE_RSA_WITH_AES_128_GCM_SHA256
        - TLS_ECDHE_RSA_WITH_CHACHA20_POLY1305_SHA256
