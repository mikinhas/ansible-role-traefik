entryPoints:
  web:
    address: ":80"
  websecure:
    address: ":443"
{% for entry_point in traefik_entrypoints %}
  {{ entry_point.name }}:
    address: ":{{ entry_point.port }}"
{% endfor %}

providers:
  file:
    filename: /etc/traefik/dynamic.yml
    watch: true

{% if traefik_acme_email %}
certificatesResolvers:
  letsencrypt:
    acme:
      email: {{ traefik_acme_email }}
      storage: /etc/traefik/acme/acme.json
      caServer: {{ traefik_acme_server }}
      httpChallenge:
        entryPoint: web
{% endif %}

log:
  level: INFO
