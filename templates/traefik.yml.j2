entryPoints:
  web:
    address: ":80"
    http:
      redirections:
        entryPoint:
          to: websecure
          scheme: https
  websecure:
    address: ":443"
{% for tcp_entry_point in traefik_tcp_entrypoints %}
  {{ tcp_entry_point.name }}:
    address: ":{{ tcp_entry_point.port }}"
{% endfor %}

providers:
  file:
    filename: /etc/traefik/dynamic.yml
    watch: true

{% if traefik_acme_email %}
certificatesResolvers:
  letsencrypt:
    acme:
      email: {{ traefik_acme_email }}
      storage: /etc/traefik/acme/acme.json
      caServer: {{ traefik_acme_server }}
      httpChallenge:
        entryPoint: web
{% endif %}

log:
  level: INFO
